APP_NAME=ScienceBowlOne
NODE_ENV=production
PORT=5000
TRUST_PROXY=true
SERVE_STATIC_FRONTEND=true
FRONTEND_DIST_PATH=../frontend/dist
CORS_ENABLED=false
CORS_ORIGINS=
ALLOW_VERCEL_PREVIEW_ORIGINS=false
MONGODB_URI=mongodb://localhost:27017/sciencebowl
JWT_SECRET=change-this-secret
JWT_EXPIRE=7d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
REQUEST_SIZE_LIMIT=10kb
PUBLIC_APP_URL=https://your-domain.example
FRONTEND_URL=https://your-domain.example
APP_URL=https://your-domain.example
PROTEST_AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
VITE_APP_NAME=ScienceBowlOne
VITE_API_URL=/api
VITE_SOCKET_URL=
VITE_API_TIMEOUT_MS=10000
VITE_DEV_BACKEND_URL=http://localhost:5000
VITE_DEV_PORT=3000
VITE_BUILD_SOURCEMAP=true
